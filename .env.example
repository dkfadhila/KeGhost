# KeGhost environment (copy to .env, isi nilainya)

# X / Twitter session cookies (live GraphQL)
TWITTER_AUTH_TOKEN=
TWITTER_CT0=

# AgentX (opsional, hanya untuk lokal dengan binary)
AGENTX_BIN=
AGENTX_HOME=
AGENTX_ACCOUNT=keghost

# CapyAi deep analysis (Virtuals compute — primary)
VIRTUALS_KEY=
VIRTUALS_MODEL=anthropic-claude-opus-4-8-fast
VIRTUALS_CHAT_MODEL=minimax-minimax-m3

# Cline (opt-in only). Set CLINE_FORCE=1 to switch chat/deep to Cline instead.
CLINE_FORCE=0
CLINE_API_KEY=
CLINE_COOKIE=
CLINE_CHAT_MODEL=cline-pass/mimo-2.5
CLINE_DEEP_MODEL=cline-pass/mimo-2.5
# Supabase (shared, persistent scan history)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=
