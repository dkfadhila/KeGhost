# KeGhost environment (copy to .env, isi nilainya)

# X / Twitter session cookies (live GraphQL)
TWITTER_AUTH_TOKEN=
TWITTER_CT0=

# AgentX (opsional, hanya untuk lokal dengan binary)
AGENTX_BIN=
AGENTX_HOME=
AGENTX_ACCOUNT=keghost

# CapyAi deep analysis (Virtuals compute)
VIRTUALS_KEY=
VIRTUALS_MODEL=anthropic-claude-opus-4-8-fast

# Cline provider (primary for chat + deep analysis). Public label: "Claude Opus 4.8".
# Cline CLI/API uses CLINE_API_KEY (Bearer). Cline Pass web uses CLINE_COOKIE.
CLINE_API_KEY=
CLINE_COOKIE=
CLINE_CHAT_MODEL=cline-pass/qwen3.7-max
CLINE_DEEP_MODEL=cline-pass/qwen3.7-max
DEEP_FALLBACK_TO_VIRTUALS=1
# Supabase (shared, persistent scan history)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=
